rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Zones: anyone can read (attendee app), only backend service writes
    match /zones/{zoneId} {
      allow read: if true;
      allow write: if false; // Backend uses Admin SDK (bypasses rules)
    }

    // Alerts: anyone can read banners, only backend service writes
    match /alerts/{alertId} {
      allow read: if true;
      allow write: if false; // Backend uses Admin SDK (bypasses rules)
    }

    // Chat history: authenticated users can read/write their own sessions
    match /chatHistory/{sessionId} {
      allow read, write: if request.auth != null;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
